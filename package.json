{
  "name": "privatdruck-mildenfurth",
  "type": "module",
  "private": true,
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "export": "nuxt generate --logLevel silent && node scripts/export.ts",
    "og": "nuxt generate --logLevel silent && node scripts/og.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier \"**/*.{css,html,json,md,mjs,ts,vue,yml}\" --write",
    "format:check": "prettier \"**/*.{css,html,json,md,mjs,ts,vue,yml}\" --check",
    "test:types": "vue-tsc -b --noEmit",
    "prepare": "nuxt prepare"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@clack/prompts": "^1.5.1",
    "@nuxt/content": "^3.14.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.13.1",
    "ansis": "^4.3.1",
    "eslint": "^10.4.1",
    "nuxt": "^4.4.8",
    "playwright": "^1.60.0",
    "prettier": "^3.8.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "srvx": "^0.11.16",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vue-tsc": "^3.3.4"
  }
}
